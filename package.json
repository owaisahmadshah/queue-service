{
  "name": "queue-service",
  "version": "1.0.0",
  "description": "Scalable background task processing engine for reliable notification delivery using BullMQ, Redis, and PostgreSQL.",
  "type": "module",
  "main": "src/index.ts",
  "scripts": {
    "start": "node dist/index.js",
    "dev": "tsx watch --env-file .env src/index.ts",
    "worker": "ts-node src/workers/index.ts",
    "prepare": "husky",
    "build": "tsc --noEmit",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "migrate": "tsx --env-file .env src/db/migrate.ts"
  },
  "keywords": [
    "nodejs",
    "bullmq",
    "redis",
    "job-queue",
    "background-jobs",
    "distributed-systems",
    "notifications"
  ],
  "author": "Owais Ahmad Shah",
  "license": "MIT",
  "dependencies": {
    "bullmq": "^5.76.4",
    "cors": "^2.8.6",
    "express": "^5.2.1",
    "ioredis": "^5.10.1",
    "morgan": "^1.10.1",
    "pg": "^8.20.0",
    "winston": "^3.19.0",
    "zod": "^4.4.2"
  },
  "devDependencies": {
    "@commitlint/cli": "^20.5.3",
    "@commitlint/config-conventional": "^20.5.3",
    "@types/cors": "^2.8.19",
    "@types/express": "^5.0.6",
    "@types/morgan": "^1.9.10",
    "@types/node": "^25.6.0",
    "@types/pg": "^8.20.0",
    "husky": "^9.1.7",
    "nodemon": "^3.1.14",
    "prettier": "^3.8.3",
    "ts-node": "^10.9.2",
    "tsx": "^4.21.0",
    "typescript": "^6.0.3"
  }
}
